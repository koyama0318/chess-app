{
  "name": "chess-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "cd wasm && wasm-pack build --target web --out-dir ../wasm-pkg",
    "build:web": "vite build",
    "build": "bun run build:wasm && bun run build:web",
    "dev": "bun run build:wasm && vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "stockfish": "^18.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^29.0.1",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-wasm": "^3",
    "vitest": "^4.1.1",
    "wrangler": "^4",
    "@eslint/js": "^9",
    "eslint": "^9",
    "typescript-eslint": "^8"
  }
}
